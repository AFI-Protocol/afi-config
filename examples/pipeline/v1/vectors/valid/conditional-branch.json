{
  "schema": "afi.pipeline.v1",
  "pipelineId": "conditional-branch",
  "pipelineVersion": "v2.0.0",
  "entry": "tech",
  "nodes": [
    {
      "id": "tech",
      "category": "technical",
      "pluginId": "technical-indicators",
      "pluginVersion": "1.0.0"
    },
    {
      "id": "news",
      "category": "news",
      "pluginId": "newsdata-features",
      "pluginVersion": "1.0.0",
      "critical": false,
      "failurePolicy": "degrade"
    },
    {
      "id": "sent",
      "category": "sentiment",
      "pluginId": "perp-sentiment",
      "pluginVersion": "1.0.0"
    },
    {
      "id": "merge",
      "category": "merge",
      "pluginId": "declared-fields-merge",
      "pluginVersion": "2.1.0",
      "join": {
        "policy": "all",
        "merge": {
          "strategy": "declared-fields",
          "conflictRule": "prefer:news"
        }
      }
    },
    {
      "id": "score",
      "category": "scorer",
      "pluginId": "mean-reversion-scorer",
      "pluginVersion": "1.0.0"
    }
  ],
  "edges": [
    {
      "from": "tech",
      "to": "news",
      "condition": {
        "any": [
          {
            "in": {
              "path": "/context/timeframe",
              "values": [
                "1h",
                "4h"
              ]
            }
          },
          {
            "not": {
              "eq": {
                "path": "/context/assetClass",
                "value": "perp"
              }
            }
          }
        ]
      },
      "optional": true
    },
    {
      "from": "tech",
      "to": "sent"
    },
    {
      "from": "news",
      "to": "merge",
      "fromPort": "features",
      "toPort": "news"
    },
    {
      "from": "sent",
      "to": "merge"
    },
    {
      "from": "merge",
      "to": "score"
    }
  ]
}
