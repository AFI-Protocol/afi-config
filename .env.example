# afi-config environment variables
#
# This repo is a configuration / JSON Schema library with no runtime server,
# so it requires no secrets to build or test. The only supported variable
# tunes a local/CI tooling threshold. Copy this file to `.env` to override.

# Maximum allowed size (in KB) for any git-tracked file before the large-file
# guard (scripts/check-file-size.mjs, `npm run check:file-size`) fails.
# Default: 1024 (1 MB).
AFI_MAX_FILE_KB=1024
