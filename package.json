{
  "name": "afi-config",
  "version": "0.1.0",
  "description": "Canonical configuration and JSON Schema library for AFI Protocol",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepare": "husky && npm run build",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "check:file-size": "node scripts/check-file-size.mjs",
    "dead-code": "knip --no-config-hints",
    "deps:check": "knip --dependencies --no-config-hints",
    "duplicates": "jscpd",
    "check:tech-debt": "node scripts/check-tech-debt.mjs",
    "check:agents-doc": "node scripts/check-agents-doc.mjs",
    "validate": "vitest run tests/schema-validation.test.ts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "lint-staged": {
    "*.{ts,js,mjs,cjs}": [
      "eslint --fix",
      "prettier --write",
      "node scripts/check-tech-debt.mjs"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write --ignore-unknown"
    ],
    "AGENTS.md": [
      "node scripts/check-agents-doc.mjs"
    ],
    "*": [
      "node scripts/check-file-size.mjs"
    ]
  },
  "keywords": [
    "afi-protocol",
    "config",
    "json-schema",
    "validation",
    "schemas"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/AFI-Protocol/afi-config.git"
  },
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.1.1",
    "@vitest/coverage-v8": "^4.1.10",
    "ajv": "^8.12.0",
    "ajv-formats": "^3.0.1",
    "eslint": "^10.7.0",
    "husky": "^9.1.7",
    "jscpd": "^5.0.12",
    "knip": "^6.27.0",
    "lint-staged": "^17.1.0",
    "prettier": "^3.9.5",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.64.0",
    "vitest": "^4.0.14"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
